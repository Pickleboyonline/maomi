{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Maomi",
  "scopeName": "source.maomi",
  "comment": "Minimal TextMate grammar — LSP semantic tokens handle most highlighting. TextMate covers imports (not in AST after resolution), comments, strings, numbers, operators.",
  "patterns": [
    { "include": "#doc-comments" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords-import" },
    { "include": "#keywords-all" },
    { "include": "#types" },
    { "include": "#constants-boolean" },
    { "include": "#numbers-float" },
    { "include": "#numbers-integer" },
    { "include": "#struct-literal" },
    { "include": "#operator-arrow" },
    { "include": "#operator-pipe" },
    { "include": "#operators-comparison" },
    { "include": "#operators-arithmetic" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "doc-comments": {
      "match": "///.*$",
      "name": "comment.line.documentation.maomi"
    },
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.maomi"
    },
    "keywords-import": {
      "match": "\\b(import|from|as)\\b",
      "name": "keyword.control.import.maomi"
    },
    "keywords-all": {
      "match": "\\b(fn|let|if|else|struct|type|with|scan|map|fold|while|do|limit|grad|value_and_grad|cast|comptime|in|and|or|not)\\b",
      "name": "keyword.other.maomi"
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(f32|f64|bf16|i32|i64|bool|Key)\\b",
          "name": "storage.type.primitive.maomi"
        },
        {
          "match": "(?<=:\\s*)([A-Z]\\w*)\\b",
          "name": "entity.name.type.struct.maomi"
        }
      ]
    },
    "constants-boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.maomi"
    },
    "struct-literal": {
      "match": "\\b([A-Z]\\w*)\\s*(?=\\{)",
      "captures": {
        "1": { "name": "entity.name.type.struct.maomi" }
      }
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.maomi",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.maomi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.maomi" }
      }
    },
    "numbers-float": {
      "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b|\\b\\d+[eE][+-]?\\d+\\b",
      "name": "constant.numeric.float.maomi"
    },
    "numbers-integer": {
      "match": "\\b\\d+\\b",
      "name": "constant.numeric.integer.maomi"
    },
    "operator-arrow": {
      "match": "->",
      "name": "punctuation.separator.arrow.maomi"
    },
    "operator-pipe": {
      "match": "\\|>",
      "name": "keyword.operator.pipe.maomi"
    },
    "operators-comparison": {
      "match": "==|!=|<=|>=|<|>",
      "name": "keyword.operator.comparison.maomi"
    },
    "operators-arithmetic": {
      "match": "\\*\\*|[+\\-*/]|@",
      "name": "keyword.operator.arithmetic.maomi"
    },
    "punctuation": {
      "patterns": [
        { "match": "[{}]", "name": "punctuation.section.block.maomi" },
        { "match": "[()]", "name": "punctuation.section.parens.maomi" },
        { "match": "[\\[\\]]", "name": "punctuation.section.brackets.maomi" },
        { "match": ",", "name": "punctuation.separator.comma.maomi" },
        { "match": ":", "name": "punctuation.separator.colon.maomi" },
        { "match": ";", "name": "punctuation.terminator.statement.maomi" },
        { "match": "\\.", "name": "punctuation.accessor.dot.maomi" },
        { "match": "(?<![!=])=(?!=)", "name": "keyword.operator.assignment.maomi" }
      ]
    }
  }
}
